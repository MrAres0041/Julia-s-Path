[layer_names]

2d_physics/layer_1="Player"
2d_physics/layer_2="NPC"
2d_physics/layer_3="Objects"
2d_physics/layer_4="Speaker"

[rendering]

textures/canvas_textures/default_texture_filter=0
environment/defaults/default_clear_color=Color(0.0896371, 0.0779653, 0.074815, 1)
