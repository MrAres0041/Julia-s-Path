; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Julia's Cycle"
run/main_scene="uid://cbs2n3jjsran"
config/features=PackedStringArray("4.4", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/image="uid://cxc6haeobvfht"
config/icon="uid://bevejk2847ll"
boot_splash/minimum_display_time=2000

[autoload]

Dialogic="*res://addons/dialogic/Core/DialogicGameHandler.gd"
GPSignals="*res://scripts/globals/g_phone.gd"
GPlayer="*res://scripts/globals/g_player.gd"
GAudio="*res://scripts/globals/g_audio.gd"
IndexConfigs="*res://scripts/ui/indexConfigs.gd"

