if {Act1.pills_taken} == true:
	[signal arg="DoorClose"]
	audio music_dialogic - [fade="0.5"]
	[wait time="0.5"]
	[signal arg="End"]
else:
	Narrator: The bed lies ahead.
	Narrator: You wish you could stay there forever.
	Narrator: Not like becoming a vegetable would make anyone want you more.
	[wait time="0.5"]
	[signal arg="DialogueEnded"]